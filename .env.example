# =============================================================================
#  Environment Variables — copy to .env and fill in real values
#  cp .env.example .env
# =============================================================================

# --- Airflow container UID ---
AIRFLOW_UID=50000

# --- Redshift connection ---
DB_HOST=your-redshift-cluster.region.redshift.amazonaws.com
DB_PORT=5439
DB_NAME=your_database
DB_ID=your_username
DB_PW=your_password

# --- Slack notifications ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# --- Google Sheets credentials ---
GOOGLE_CREDENTIALS_PATH=/opt/airflow/google-credentials.json
